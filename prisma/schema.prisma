generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// Source de vérité unique pour l'identité partagée entre Blindtoss, Memoss
// et toute future app "-oss". Blindtoss garde une table User locale en
// miroir (voir lib/sharedAuth.ts côté Blindtoss) pour ses clés étrangères
// (GameResult, UserAchievement, UserTrackNote) — cooloss est la seule source
// qui gère mot de passe, avatar et flag admin.
model User {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  displayName  String?
  passwordHash String
  avatarFile   String?
  isAdmin      Boolean  @default(false)
  // Rôle intermédiaire, spécifique à Memoss : accès à l'historique des
  // légendes / timeline (isAdmin y donne accès aussi, évidemment). N'a pas
  // de sens pour Blindtoss — pas répliqué dans son miroir local.
  isHabitue    Boolean  @default(false)
  createdAt    DateTime @default(now())
}
